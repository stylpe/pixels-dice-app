{
  "name": "dice",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite --host localhost --port 5173 --strictPort",
    "dev:usb": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "adb:reverse": "adb reverse tcp:5173 tcp:5173",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "full-validate": "pnpm check && pnpm test && pnpm build",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@systemic-games/pixels-web-connect": "^1.3.1",
    "lucide": "^1.11.0"
  }
}
