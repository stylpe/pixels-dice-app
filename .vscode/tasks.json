{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"dev",
				"--",
				"--host",
				"localhost",
				"--port",
				"5173",
				"--strictPort"
			],
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "custom",
					"pattern": {
						"regexp": "^(?!x)x"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "Local:\\s+http://localhost:5173/"
					}
				}
			],
			"group": "build"
		},
		{
			"label": "build",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}