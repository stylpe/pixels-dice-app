{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"dev:desktop"
			],
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "custom",
					"pattern": {
						"regexp": "^(?!x)x"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "Local:\\s+http://localhost:5173/"
					}
				}
			],
			"group": "build"
		},
		{
			"label": "adb-reverse",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"adb:reverse"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "dev:usb",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"dev:usb"
			],
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "custom",
					"pattern": {
						"regexp": "^(?!x)x"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "Local:\\s+http://127.0.0.1:5173/"
					}
				}
			],
			"group": "build"
		},
		{
			"label": "build",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "phone-usb",
			"dependsOn": [
				"adb-reverse",
				"dev:usb"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		}
	]
}